# OpenClaw API Token
# 从 OpenClaw 控制台获取: https://openclaw.ai/settings/api
OPENCLAW_TOKEN=your_openclaw_token_here

# 服务器配置
SERVER_IP=47.254.73.23
SERVER_PORT=8000

# 可选：数据库配置
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# 可选：日志级别
# LOG_LEVEL=INFO

# ── 飞书云文档同步 (DEPLOYMENT.md → 飞书) ──
# 需要在飞书开发者后台创建应用并开通 docx:document + wiki:wiki:readonly 权限
FEISHU_DOC_APP_ID=cli_xxxxxxxxxx
FEISHU_DOC_APP_SECRET=xxxxxxxxxxxxxxxx
FEISHU_WIKI_URL=https://my.feishu.cn/wiki/xxxxxxxxxxxxx  # wiki 页面 URL，首次运行自动解析
FEISHU_DOC_ID=                          # 自动从 wiki URL 解析填充，无需手动设置
